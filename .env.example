# Copy to .env for local Docker Compose. Values below are placeholders, not production secrets.

SPRING_PROFILES_ACTIVE=prod
JPA_DDL_AUTO=validate

POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_PORT=5432

REDIS_PORT=6379
MQTT_PORT=1883

BACKEND_PORT=8080
FRONTEND_PORT=8088

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TOKEN_TTL=PT15M
JWT_REFRESH_TOKEN_TTL=P30D

PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=replace-with-local-webhook-secret
VOICE_PROVIDER=mock
VOICE_PROVIDER_KEY=replace-with-provider-key-when-real-provider-is-configured
VOICE_WEBHOOK_SECRET=replace-with-local-voice-webhook-secret
MQTT_PROVIDER=mock
MQTT_TLS_REQUIRED=false
NOTIFICATION_PUSH_PROVIDER=mock
NOTIFICATION_EMAIL_PROVIDER=mock

CORS_ALLOWED_ORIGINS=http://localhost:8088
NEXUS_JOBS_ENABLED=true
NEXUS_KEY_PREFIX=nexus-local

VITE_API_BASE_URL=/api/v1
VITE_WS_URL=/ws
VITE_APP_NAME=NEXUS Smart Cyber Esports
VITE_ENABLE_PWA=true
VITE_ENABLE_VOICE=false
